{
  "name": "@fagaos/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FagaOS product web app (Next.js 14 App Router). Bootstraps the workspace shell from @fagaos/workspace-shell and @fagaos/ui-read-model, talks to the control-plane server over a typed HTTP client, and renders the persistent navigation for the Phase 3 product UI.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fagaos/onboarding": "*",
    "@fagaos/ui-read-model": "*",
    "@fagaos/workspace-shell": "*",
    "next": "^15.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
