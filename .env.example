# FagaOS audit log signing key. Must be at least 32 bytes / 32 characters.
# Generate with:  openssl rand -hex 32
FAGAOS_AUDIT_KEY=

# Optional local control-plane state file for restart persistence.
# Leave unset to use in-memory state.
FAGAOS_CONTROL_PLANE_STATE_FILE=.fagaos/control-plane-state.json
