{
  "name": "fagaos",
  "version": "0.0.0",
  "private": true,
  "description": "FagaOS — capability-based agent operating system",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run -ws --if-present build",
    "build:schema": "npm run -ws --if-present build:schema",
    "lint": "eslint --no-error-on-unmatched-pattern \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\" \"packages/*/tests/**/*.ts\" \"apps/*/src/**/*.ts\" \"apps/*/src/**/*.tsx\" \"apps/*/tests/**/*.ts\" \"apps/*/tests/**/*.tsx\" \"scripts/**/*.ts\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package:verify": "npm run build && tsx scripts/verify-packaging.ts",
    "audit:dependencies": "npm audit --audit-level=high",
    "release:gate": "tsx scripts/release-gate.ts",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run package:verify && npm run test:coverage && npm run audit:dependencies && npm run release:gate"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
