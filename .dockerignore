# Build artifacts
node_modules/
dist/
coverage/
*.tsbuildinfo

# Local environment / secrets
.env
.env.*
!.env.example

# Multica runtime artifacts (not part of the project source)
.agent_context/
.multica/
.opencode/
AGENTS.md

# Git
.git/
.gitignore

# Docker files themselves are not needed inside the image
Dockerfile
docker-compose.yml
.dockerignore

# Editor / OS files
.DS_Store
.vscode/
.idea/
*.swp

# Documentation and CI are not needed at runtime
docs/
.github/

# Tests are not shipped in the production image
packages/*/tests/
apps/*/tests/
